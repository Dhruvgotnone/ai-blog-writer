# ============================================
# AI Blog Writer - Environment Configuration
# ============================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/ai-blog-writer
# For MongoDB Atlas (cloud): mongodb+srv://username:password@cluster.mongodb.net/ai-blog-writer

# Hugging Face API
# Get your free API key at: https://huggingface.co/settings/tokens
HF_API_KEY=hf_your_hugging_face_api_key_here

# JWT Secret (use a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_1234567890

# CORS Origin (frontend URL)
CORS_ORIGIN=http://localhost:3000
